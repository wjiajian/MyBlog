# ====================================
# MyBlog 环境变量配置
# ====================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ====================================
# 数据库配置 (必需)
# ====================================
# PostgreSQL 数据库连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://bloguser:your_new_password@localhost:5432/myblog

# ====================================
# 服务器配置
# ====================================
# 服务器运行端口 (默认: 3000)
# PORT=3000

# 运行环境: development | production
# NODE_ENV=development

# 照片上传单文件大小限制（MB，默认 50）
# PHOTO_UPLOAD_MAX_MB=50

# 照片墙 OSS 基础地址（不含末尾 /）
# 服务端会将 metadata 中以 /photowall/ 开头的路径改写为该地址
# 示例：https://myblog-photowall.oss-cn-hangzhou.aliyuncs.com
# OSS_PHOTOWALL_BASE_URL=

# 前端兜底地址（用于构建时 metadata 或无后端改写场景）
# 示例：https://myblog-photowall.oss-cn-hangzhou.aliyuncs.com
# VITE_OSS_PHOTOWALL_BASE_URL=

# ====================================
# OneDrive -> OSS 同步配置（可选）
# ====================================
# 是否启用 OneDrive 增量同步
# ONEDRIVE_SYNC_ENABLED=false

# 定时轮询间隔（秒，默认 600）
# ONEDRIVE_SYNC_POLL_INTERVAL_SECONDS=600

# Microsoft Entra 应用信息
# ONEDRIVE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ONEDRIVE_CLIENT_SECRET=your_client_secret

# OneDrive driveId（Graph API 中的 drive 标识）
# ONEDRIVE_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OneDrive 源目录（相对于 drive 根目录），默认 PhotoWall
# ONEDRIVE_SOURCE_FOLDER_PATH=PhotoWall

# 可选：若使用 refresh_token 模式，配置 refresh token 及 scope
# ONEDRIVE_REFRESH_TOKEN=
# ONEDRIVE_REFRESH_SCOPE=Files.Read offline_access

# 可选：Webhook 公网地址（用于接收 Graph 通知）
# 示例：https://your-domain.com/api/onedrive-sync/webhook
# ONEDRIVE_WEBHOOK_URL=
# 可选：Webhook clientState 校验值
# ONEDRIVE_WEBHOOK_CLIENT_STATE=
# 可选：手动指定订阅资源（默认自动使用 /drives/{driveId}/root）
# ONEDRIVE_SUBSCRIPTION_RESOURCE=
# 到期前多久自动续订（分钟，默认 720）
# ONEDRIVE_SUBSCRIPTION_RENEW_BEFORE_MINUTES=720

# OSS 写入配置（同步服务上传文件使用）
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=myblog-photowall
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# 可选：自定义 endpoint（私有云/内网场景）
# OSS_ENDPOINT=

# ====================================
# 可选配置
# ====================================
# 如需自定义其他配置，可在此添加

# ====================================
# 管理员认证配置
# ====================================
# 管理员用户名
ADMIN_USERNAME=admin
# 管理员密码（开发模式，生产环境请使用 ADMIN_PASSWORD_HASH）
ADMIN_PASSWORD=admin123
# 生产环境密码哈希（使用 bcrypt 生成）
# 生成命令：node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
# ADMIN_PASSWORD_HASH=$2a$10$...
# JWT 密钥（建议使用随机字符串）
JWT_SECRET=your_random_secret_key_change_in_production
